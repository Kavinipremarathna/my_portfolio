{
  "version": 2,
  "buildCommand": "cd client && npm run build",
  "installCommand": "npm install && cd client && npm install && cd ../server && npm install",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "server/index.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server"
    },
    {
      "source": "/(.*)",
      "destination": "/server"
    }
  ]
}
