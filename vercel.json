{
  "version": 2,
  "buildCommand": "cd client && npm run build",
  "installCommand": "npm install && cd client && npm install",
  "functions": {
    "api/auth.js": {
      "includeFiles": "server/data/users.json"
    },
    "api/projects.js": {
      "includeFiles": "server/data/projects.json"
    },
    "api/skills.js": {
      "includeFiles": "server/data/skills.json"
    },
    "api/gallery.js": {
      "includeFiles": "server/data/gallery.json"
    },
    "api/articles.js": {
      "includeFiles": "server/data/articles.json"
    }
  },
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/projects/(.*)",
      "destination": "/api/projects?route=$1"
    },
    {
      "source": "/api/skills/(.*)",
      "destination": "/api/skills?route=$1"
    },
    {
      "source": "/api/auth/(.*)",
      "destination": "/api/auth?route=$1"
    },
    {
      "source": "/api/gallery/(.*)",
      "destination": "/api/gallery?route=$1"
    },
    {
      "source": "/api/articles/(.*)",
      "destination": "/api/articles?route=$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
